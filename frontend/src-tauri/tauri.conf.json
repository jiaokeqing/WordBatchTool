{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "格式通",
  "version": "1.0.0",
  "identifier": "com.jiaokeqing.geshitong",
  "build": {
    "beforeDevCommand": "node ../scripts/tauri_frontend.mjs dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "node ../scripts/tauri_frontend.mjs build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "格式通",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/word-batch-sidecar"
    ]
  }
}
